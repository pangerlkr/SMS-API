# -----------------------------------------------------------------------
# Environment – set to "production" in production deployments
# -----------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------
PORT=3000

# -----------------------------------------------------------------------
# JWT – REQUIRED in production (min 32 random characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# -----------------------------------------------------------------------
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------
# CORS – comma-separated list of allowed origins, or * to allow all.
# Defaults to false (block all cross-origin) in production when not set.
# Examples:
#   CORS_ORIGIN=https://app.example.com
#   CORS_ORIGIN=https://app.example.com,https://admin.example.com
# -----------------------------------------------------------------------
# CORS_ORIGIN=*

# -----------------------------------------------------------------------
# Database path (defaults to ./data/sms_api.db)
# Use :memory: for ephemeral in-memory database (tests only)
# -----------------------------------------------------------------------
# DB_PATH=./data/sms_api.db
